# Best Texas Display — environment variables
# Copy this file to `.env.local` and fill in real values.
# The live values live in your Vercel project (Settings → Environment Variables).
# NEVER commit `.env.local` — it is gitignored.

# --- Database (required) ---
# Postgres connection string. Initialize the schema with scripts/init-db.sql.
DATABASE_URL="postgres://user:password@host:5432/database"

# --- Auth (required) ---
# Secret used to sign JWT session tokens. Use a long random string.
JWT_SECRET="change-me-to-a-long-random-string"

# --- Transactional email (required for password reset & email verification in prod) ---
# If RESEND_API_KEY is unset, reset/verification links are printed to the server
# console instead of emailed (handy for local testing — no provider needed).
# Get a key at https://resend.com and verify your sending domain there.
RESEND_API_KEY=""
# The "From" address. The domain must be verified in Resend. Use the site's own
# domain so emails aren't flagged as spoofed.
EMAIL_FROM="Best Texas Display <noreply@besttexasdisplay.com>"

# Public site origin, used to build links in emails. In prod set this to your
# real URL (e.g. https://besttexasdisplay.com). Locally it defaults to the
# request origin, so you can leave it blank for `next dev`.
NEXT_PUBLIC_SITE_URL=""

# --- Photo storage: Cloudflare R2 (required for uploads) ---
# If R2_ENDPOINT and R2_ACCESS_KEY_ID are unset, uploads fall back to a
# placeholder image (fine for local UI work, but no real photos are stored).
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="best-texas-display"
# Public base URL for served images (R2 public bucket or custom domain).
R2_PUBLIC_URL="https://<your-public-r2-domain>"

# --- Google Maps (required for the interactive map) ---
# Exposed to the browser (NEXT_PUBLIC_*); restrict it by HTTP referrer in the
# Google Cloud console.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=""
